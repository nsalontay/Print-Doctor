<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required: PyInstaller bundles a frozen Python interpreter that
         allocates executable memory in ways the hardened runtime would
         otherwise block. Without this, the .app crashes at launch. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required: PyInstaller's bootloader loads dylibs (PySide6, numpy
         BLAS, trimesh native deps) from inside the bundle that aren't
         signed by Apple. Library validation would reject them. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required for multiprocessing: child workers inherit DYLD_*
         variables from the parent's PyInstaller environment. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
